server {
    server_name scaletta.live www.scaletta.live;

    # ===== Proxy Buffer Settings =====
    proxy_buffer_size 16k;
    proxy_buffers 4 16k;
    proxy_busy_buffers_size 32k;
    large_client_header_buffers 4 16k;

    # ===== SOCKET.IO (WebSockets / WSS) =====
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3000/socket.io/;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;


    }

    # ===== TWITCH EVENTSUB (Webhook) =====
    location /eventsub {
        proxy_pass http://127.0.0.1:3000;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 60s;

        proxy_pass_header X-Twitch-Eventsub-Message-Id;
        proxy_pass_header X-Twitch-Eventsub-Message-Retry;
        proxy_pass_header X-Twitch-Eventsub-Message-Type;
        proxy_pass_header X-Twitch-Eventsub-Message-Signature;
        proxy_pass_header X-Twitch-Eventsub-Message-Timestamp;
        proxy_pass_header X-Twitch-Eventsub-Subscription-Type;
        proxy_pass_header X-Twitch-Eventsub-Subscription-Version;
    }

    # ===== EXPRESS / WEBSITE =====
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ===== SSL =====
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/scaletta.live/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/scaletta.live/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# ===== HTTP Redirect zu HTTPS =====
server {
    listen 80;
    server_name scaletta.live www.scaletta.live;
    return 301 https://$host$request_uri;
}