                                                    <%=locals[boxes].family==="'Fira Code', monospace" ? 'selected' : ''
                                                    %>>Fira Code</option>
                                                <option value="'Ubuntu', sans-serif"
                                                    <%=locals[boxes].family==="'Ubuntu', sans-serif" ? 'selected' : ''
                                                    %>>Ubuntu</option>
                                                <option value="'Bebas Neue', sans-serif"
                                                    <%=locals[boxes].family==="'Bebas Neue', sans-serif" ? 'selected'
                                                    : '' %>>Bebas Neue</option>
                                                <option value="'Space Grotesk', sans-serif"
                                                    <%=locals[boxes].family==="'Space Grotesk', sans-serif" ? 'selected'
                                                    : '' %>>Space Grotesk</option>
                                                <option value="'Josefin Sans', sans-serif"
                                                    <%=locals[boxes].family==="'Josefin Sans', sans-serif" ? 'selected'
                                                    : '' %>>Josefin Sans</option>
                                                <option value="'Fraunces', serif"
                                                    <%=locals[boxes].family==="'Fraunces', serif" ? 'selected' : '' %>
                                                    >Fraunces</option>
                                                <option value="'Caveat', cursive"
                                                    <%=locals[boxes].family==="'Caveat', cursive" ? 'selected' : '' %>
                                                    >Caveat</option>
                                            </select>
                                        </div>
                                        <div class="form-group">
