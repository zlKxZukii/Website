                            <div class="upload-group">
                                <h2>Bild / Video / GIF</h2>
                                <form class="upload-form" action="/subongoings/upload/subongoing" method="POST"
                                    enctype="multipart/form-data"
                                    onsubmit="this.querySelector('.submit-btn').disabled = true; this.querySelector('.submit-btn').innerText = 'Wird verarbeitet...';">
                                    <label for="image-upload" class="custom-file-button">Datei auswählen</label>
                                    <input id="image-upload" type="file" name="image" accept="image/*,video/*"
                                        class="hidden-input">

                                    <button type="submit" class="submit-btn">Hochladen</button>
                                    <p id="image-name" class="file-status">Keine Datei gewählt</p>
                                </form>
                            </div>
                            <div class="upload-group">
                                <h2>Sound</h2>

                                <form class="upload-form" action="/subongoings/upload/subongoing" method="POST"
                                    enctype="multipart/form-data"
                                    onsubmit="this.querySelector('.submit-btn').disabled = true; this.querySelector('.submit-btn').innerText = 'Wird verarbeitet...';">
                                    <label for="sound-upload" class="custom-file-button">Sound auswählen</label>
                                    <input id="sound-upload" name="sound" type="file" accept="audio/*"
                                        class="hidden-input">

                                    <button type="submit" class="submit-btn">Hochladen</button>
                                    <p id="sound-name" class="file-status">Kein Sound gewählt</p>
                                </form>
                            </div>
                        </div>

                        <div class="test-window">
                            <iframe src="<%= locals.link %>" frameborder="0" allow="autoplay"></iframe>
                            <button onclick="testWS(this, 'subongoings')">Teste Mich.</button>
                        </div>

                    </div>
                    <h2
