            <!-- states -->
            <script>
                function checkStateOfBox() {
                    const state = document.getElementById("subongoingsState")
                    const viewerRainbow = document.getElementById("viewerRainbow")
                    const streamerRainbow = document.getElementById("streamerRainbow")
                    const bundleRainbow = document.getElementById("bundleRainbow")
                    const tierRainbow = document.getElementById("tierRainbow")
                    const postRainbow = document.getElementById("postRainbow")
                    const streakRainbow = document.getElementById("streakRainbow")
                    const cumulativRainbow = document.getElementById("cumulativRainbow")
                    const stateArr = [state, viewerRainbow, streamerRainbow, tierRainbow, bundleRainbow, cumulativRainbow, streakRainbow, cumulativRainbow]
                    for (const state of stateArr) {
                        const stateBox = document.getElementById(state.id + "State")
                        if (state.checked) {
                            if (state.id === 'subongoingsState') {
                                stateBox.innerText = "Aktiv"
                            }
                            stateBox.style.color = "#4caf50"
                        }
                        else {
                            if (state.id === 'subongoingsState') {
                                stateBox.innerText = "Inaktiv"
                            }
                            stateBox.style.color = "red"
                        }
                    }
                }
                checkStateOfBox()
            </script>
            <!-- Rainbow checker -->
            <script>
                function checkRgb() {

                    const viewerRainbow = document.getElementById("viewerRainbow")
                    const streamerRainbow = document.getElementById("streamerRainbow")
                    const bundleRainbow = document.getElementById("bundleRainbow")
                    const tierRainbow = document.getElementById("tierRainbow")
                    const postRainbow = document.getElementById("postRainbow")
                    const streakRainbow = document.getElementById("streakRainbow")
                    const cumulativRainbow = document.getElementById("cumulativRainbow")
                    const stateArr = [viewerRainbow, streamerRainbow, tierRainbow, postRainbow, bundleRainbow, streakRainbow, cumulativRainbow]
                    for (const state of stateArr) {
                        const headline = document.getElementById(state.id.replace("Rainbow", ""))
                        if (!headline.classList.entries.length <= 0) {
                            removeClasses(headline)
                        }
                        if (state.checked) {
                            headline.classList.add("rainbow-liquid");
                            if (headline.id === 'viewer') {

                                const viewerSelector = document.getElementById('viewerAnimation');
                                viewerSelector.value = 'off'
                                headline.innerHTML = "Zuschauer"
                            }
                            if (headline.id === 'streamer') {
                                const streamerSelector = document.getElementById('streamerAnimation');
                                streamerSelector.value = 'off'
                                headline.innerHTML = "Streamer"
                            }
                            if (headline.id === 'tier') {
                                const tierSelector = document.getElementById('tierAnimation');
                                tierSelector.value = 'off'
                                headline.innerHTML = "Tier (Stufe)"
                            }
                            if (headline.id === 'post') {
                                const postSelector = document.getElementById('postAnimation');
                                postSelector.value = 'off'
                                headline.innerHTML = "Zuschauer Nachricht"
                            }
                            if (headline.id === 'bundle') {
                                const bundleRainbow = document.getElementById('bundleAnimation');
                                bundleRainbow.value = 'off'
                                headline.innerHTML = "Dauer"
                            }
                            if (headline.id === 'streak') {
                                const streakSelector = document.getElementById('streakAnimation');
                                streakSelector.value = 'off'
                                headline.innerHTML = "Gerade"
                            }
                            if (headline.id === 'cumulativ') {

                                const cumulativSelector = document.getElementById('cumulativAnimation');
                                cumulativSelector.value = 'off'
                                headline.innerHTML = "Gesamtanzahl"
                            }
                        }
                        else {
                            headline.classList.remove("rainbow-liquid");
                        }
                    }
                }
                checkRgb()
            </script>
            <!-- Animation Handler -->
            <script>
                const classArr = ['rainbow-liquid', 'off', 'glitch', 'flicker', 'staircase', 'floating', 'reveal', 'echo-pulse', 'wave']
                const viewerSelector = document.getElementById('viewerAnimation');
                const viewerTarget = document.getElementById('viewer');

                viewerSelector.addEventListener('change', function () {
                    const viewerRainbow = document.getElementById("viewerRainbow")
                    const viewerRainbowState = document.getElementById("viewerRainbowState")

                    viewerRainbow.checked = false;
                    viewerRainbowState.style.color = "red";
                    viewerTarget.innerHTML = 'Zuschauer'
                    removeClasses(viewerTarget)
                    const mode = this.value;
                    viewerTarget.classList.add(mode)
                    if (mode === 'wave') {
                        wave()
                    }
                    else if (mode === 'glitch') {
                        glitch()
                    }
                    else if (mode === 'staircase') {
                        staircase()
                    }
                    else if (mode === 'off') {
                        viewerTarget.innerHTML = "Zuschauer"
                        removeClasses(viewerTarget)
                    }
                });
            </script>
