            <script>
                // Elemente auswählen (inklusive der neuen Größe)
                const fontWeightSelect = document.getElementById('font-weight');
                const fontDecorationSelect = document.getElementById('font-decoration');
                const fontFamilySelect = document.getElementById('font-family');
                const fontSizeInput = document.getElementById('font-size');
                const sizeValueDisplay = document.getElementById('size-value');
                const testerArea = document.getElementById('responseText');

                // Zentrale Update-Funktion
                function updatePreview() {
                    // Werte aus den Selectern/Inputs holen
                    const weight = fontWeightSelect.value;
                    const style = fontDecorationSelect.value;
                    const family = fontFamilySelect.value;
                    const size = fontSizeInput.value;

                    // Werte auf die Textarea anwenden
                    testerArea.style.fontWeight = weight;
                    testerArea.style.fontStyle = style;
                    testerArea.style.fontFamily = family;
                    testerArea.style.fontSize = size + "px";
                }

                // Event-Listener für alle Steuerelemente
                fontWeightSelect.addEventListener('change', updatePreview);
                fontDecorationSelect.addEventListener('change', updatePreview);
                fontFamilySelect.addEventListener('change', updatePreview);
                fontSizeInput.addEventListener('input', updatePreview); // 'input' für Live-Vorschau beim Schieben

                // Initialer Aufruf
                updatePreview();
            </script>
