                                                <option value="'Roboto Flex', sans-serif"
                                                    <%=locals[boxes].family==="'Roboto Flex', sans-serif" ? 'selected'
                                                    : '' %>>Roboto Flex</option>
                                                <option value="'Montserrat', sans-serif"
                                                    <%=locals[boxes].family==="'Montserrat', sans-serif" ? 'selected'
                                                    : '' %>>Montserrat</option>
                                                <option value="'Poppins', sans-serif"
                                                    <%=locals[boxes].family==="'Poppins', sans-serif" ? 'selected' : ''
                                                    %>>Poppins</option>
                                                <option value="'Open Sans', sans-serif"
                                                    <%=locals[boxes].family==="'Open Sans', sans-serif" ? 'selected'
                                                    : '' %>>Open Sans</option>
                                                <option value="'Oswald', sans-serif"
                                                    <%=locals[boxes].family==="'Oswald', sans-serif" ? 'selected' : ''
