<link rel="stylesheet" href="/css/boxes/extra/animations.css">
<link rel="stylesheet" href="/css/boxes/later.css">

<div class="standard-box" id="alert-box"></div>

<script src="/js/boxes/extra/animations.js"></script>
<script src="/socket.io/socket.io.js"></script>
<script>

    const socket = io();
    const username = "<%= targetUser %>";
    console.log("Client-seitig: Ich bin " + username);

    socket.on("connect", () => {
        console.log("Erfolgreich mit Server verbunden!");
        socket.emit("join-room", username);
    });

    socket.on("new-alert", async (data) => {
        const alertBox = document.getElementById("alert-box");

        if (data.type === 'Shoutout') {
            // --- SHOUTOUT LOGIC ---
            alertBox.innerHTML = `
                <div class="introduction-text">
                    <video style="height: 200px; border-radius:100px;" src="${data.viewerProfilePicture}" autoplay muted playsinline></video>
                    <h2 style="font-size: 50px; margin-left:10px; color:${data.color};">${data.viewerName}</h2>
                </div>
                <div class="audio">
                    <audio id="alertSound" src="${data.sound}" autoplay></audio>
                </div>`;

            alertBox.classList.add('fade-shoutout');
            await new Promise(res => setTimeout(res, 6000));
            alertBox.classList.remove('fade-shoutout');

            alertBox.innerHTML = `
                <div class="shoutout-player">
                    <div id="videoContainer"></div>
                    <p style="color:${data.color};">${data.responseText}</p>
                    <img src="${data.gameImg}" alt="">
                </div>`;

            // Dynamisches Video-Handling für Shoutout-Video
            const vidContainer = document.getElementById("videoContainer");
            const shoutoutVid = document.createElement('video');
            shoutoutVid.src = data.video;
            shoutoutVid.autoplay = true;
            shoutoutVid.preload = "auto";
            shoutoutVid.onloadeddata = () => shoutoutVid.play();
            vidContainer.appendChild(shoutoutVid);

            alertBox.classList.remove('standard-box');
            alertBox.classList.add('fade-shoutout-in');

            await new Promise(res => setTimeout(res, data.duration * 1000 - 2000));
            alertBox.classList.remove('fade-shoutout-in');
            alertBox.classList.add('fade-shoutout-out');

            await new Promise(res => setTimeout(res, 3000));
            alertBox.innerHTML = "";
            alertBox.classList.remove('fade-shoutout-out');
            alertBox.classList.add('standard-box');

        } else {
            // --- STANDARD ALERT LOGIC (Abfangen der 4MB WebM) ---
            alertBox.innerHTML = `  
            <div class="alert-box-player ${data.align}">
                <div class="alert-img" id="alertImg">

                </div>
                <div class="alert-text" id="text">
                    <p style="font-family:${data.family}; font-style:${data.decoration}; font-weight:${data.weight}; font-size:${data.size}; color:${data.color};">${data.text}</p>
                </div>
                <div class="audio">
                    <audio id="alertSound" src="${data.sound}" autoplay></audio>
                </div>
            </div>`;

            const imgContainer = document.getElementById("alertImg");

            if (isVideo(data.img)) {
                const video = document.createElement('video');

                // Video-Attribute für sofortiges Rendering
                video.style.width = "100%";
                video.style.height = "auto";
                video.style.background = "transparent";
                video.autoplay = true;
                video.muted = true;
                video.playsInline = true;
                video.preload = "auto";
                video.src = data.img;

                // Der "Streaming"-Trigger: Sobald Daten fließen, anzeigen
                video.onloadeddata = () => {
                    video.play();
                    imgContainer.appendChild(video);
                };

                // Sicherstellen, dass das Laden sofort startet
                video.load();
            }
            else {
                imgContainer.innerHTML = `<img src="${data.img}" alt="/img/logo.webp">`
            }

            function isVideo(path) {
                return /\.(mp4|webm|ogg|mov|m4v)$/i.test(path);
            }

            alertBox.style.animation = `fadeInOut ${data.duration}s linear forwards`;

            startAnimation(data.id);

            const soundEl = document.getElementById("alertSound");
            if (soundEl) soundEl.volume = data.volume / 100;

            setTimeout(() => {
                alertBox.innerHTML = "";
                alertBox.style.animation = null;
            }, data.duration * 1000 + 1000);
        }
    });

    function startAnimation(id) {
        if (!id || !Array.isArray(id)) return;
        id.forEach(elementId => {
            const el = document.getElementById(elementId);
            if (!el) return;
            if (el.classList.contains('wave')) wave();
            else if (el.classList.contains('glitch')) glitch();
            else if (el.classList.contains('staircase')) staircase();
        });
    }
</script>