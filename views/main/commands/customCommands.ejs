<%- include("../../layouts/commandBar") %>
    <div class="commands-box">
        <div class="headline">
            <p>Commands</p>
            <p>Beschreibung</p>
            <p>Berechtigung</p>
            <p>Status</p>
        </div>
        <div id="customWindow">
            <div id="error-div"></div>
        </div>
        <div class="creation-buttons">
            <button onclick="deleteValues()" id="deleteButton">Löschen</button>
            <button onclick="registerCommand()">Hinzufügen</button>
            <button onclick="initSave()" id="safeButton">Speichern</button>
        </div>
    </div>


    <!-- das formatieren nicht vergessen über das textpad -->
    <script>
        let customCommands = <%- JSON.stringify(customCommandData) %>
            window.addEventListener("load", () => {
                const cKey = Object.keys(customCommands)
                cKey.sort()
                for (let i = 0; i < cKey.length; i++) {
                    document.getElementById("customWindow").innerHTML += getTemplate(cKey[i])
                }
            })
    </script>
    <script src="../js/commands/customCommands/customCommands.js"></script>
    <script src="../js/commands/customCommands/template.js"></script>
    <script src="../js/commands/logicCmds.js"></script>