<div>
    <div class="head">
        <h1>Mehr Witz. <br>
            Mehr Interaktion.<br>
            Weniger Stress. <br>
            Für dich.
        </h1>
        <div class="video-div">
            <h2>Partner von Scaletta</h2>
            <video autoplay muted loop playsinline>
                <source src="../VID/index/clip.mp4" type="video/mp4">
            </video>
            <div class="video-socials">
                <div>
                    <a href="https://www.twitch.tv/ozanityreal"><img style="height: 25px;"
                            src="../img/index/twitch_logo.png" alt="">OzanityReal</a>
                </div>

                <div>
                    <a href="https://www.tiktok.com/@ozanityreeal?_r=1&_t=ZN-92GiJ4FgeEo"> <img style="height: 25px;"
                            src="../img/index/tiktok_logo.png" alt="">OzanityReal</a>
                </div>
            </div>
