            </div>
            <div class="command-align">
                <p>
                    <%= locals.username || "Scaletta" %>
                </p>
                <p>
                    : <%= locals.jokePrompt %>
                </p>
            </div>
            <div class="command-align">
                <p>
                    Timinator
                </p>
                <p>
                    : <%= locals.socialMediaTrigger %>
                </p>
            </div>
            <div class="command-align">
                <p>
                    <%= locals.username || "Scaletta" %>
                </p>
                <p>
                    : Kontaktiere mich über Social Media: <a href="<%= locals.socialMediaPrompt %>">
