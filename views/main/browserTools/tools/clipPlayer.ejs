    <script>
        const testHead = document.getElementById('testHead');
        const headlineShadowX = document.getElementById('headlineShadowX');
        const headlineShadowY = document.getElementById('headlineShadowy'); // Hier das kleine 'y' nutzen oder im HTML ändern
        const headlineShadowColor = document.getElementById('headlineShadowColor');
        const headlineShadowOpacity = document.getElementById('headlineShadowOpacity');
        const headlineShadowBlur = document.getElementById('headlineShadowBlur');
        const headlineColor = document.getElementById('headColor');

        headlineColor.addEventListener('input', (event) => {
            const selectedColor = event.target.value;
            testHead.style.color = selectedColor;
        });

        function updateShadowHead() {

            const x = headlineShadowX.value + "px";
            const y = headlineShadowY.value + "px";
            const blur = headlineShadowBlur.value + "px";
            const color = headlineShadowColor.value;
            const opacity = headlineShadowOpacity.value / 100;

            const r = parseInt(color.slice(1, 3), 16);
            const g = parseInt(color.slice(3, 5), 16);
            const b = parseInt(color.slice(5, 7), 16);


            const shadowString = `${x} ${y} ${blur} rgba(${r}, ${g}, ${b}, ${opacity})`;

            testHead.style.textShadow = shadowString;
        }

        [headlineShadowX, headlineShadowY, headlineShadowColor, headlineShadowOpacity, headlineShadowBlur].forEach(input => {
            input.addEventListener('input', updateShadowHead);
        });

        updateShadowHead();
    </script>

    <script>
        const testClip = document.getElementById('testClip');
        const clipShadowX = document.getElementById('clipShadowX');
        const clipShadowY = document.getElementById('clipShadowY');
        const clipShadowColor = document.getElementById('clipShadowColor');
        const clipShadowOpacity = document.getElementById('clipShadowOpacity');
        const clipShadowBlur = document.getElementById('clipShadowBlur');
        const clipColor = document.getElementById('clipColor');

        clipColor.addEventListener('input', (event) => {
            const selectedColor = event.target.value;
            testClip.style.color = selectedColor;
        });

        function updateShadowClip() {

            const x = clipShadowX.value + "px";
            const y = clipShadowY.value + "px";
            const blur = clipShadowBlur.value + "px";
            const color = clipShadowColor.value;
            const opacity = clipShadowOpacity.value / 100;

            const r = parseInt(color.slice(1, 3), 16);
            const g = parseInt(color.slice(3, 5), 16);
            const b = parseInt(color.slice(5, 7), 16);


            const shadowString = `${x} ${y} ${blur} rgba(${r}, ${g}, ${b}, ${opacity})`;

            testClip.style.textShadow = shadowString;
        }

        [clipShadowX, clipShadowY, clipShadowColor, clipShadowOpacity, clipShadowBlur].forEach(input => {
            input.addEventListener('input', updateShadowClip);
        });

        updateShadowClip();
    </script>

    <script>
        const typeArr = [testHead, testClip]

        async function getColor(button) {
            const btnText = button.innerText;
            const data = { key: '<%= clipKey %>' };
            button.disabled = true;
            button.innerText = "Speichert...";
            button.style.color = 'gray';
            for (const value of typeArr) {
                const fullStyle = value.style.textShadow;

                const key = value.id.replace("test", "")
                const family = document.getElementById(key.toLocaleLowerCase() + "Family").value
                const size = document.getElementById(key.toLocaleLowerCase() + "Size").value
                const color = document.getElementById(key.toLocaleLowerCase() + "Color").value
                const shadowColor = fullStyle.match(/rgba?\(.*?\)/);
                const rgba = shadowColor[0]
                const values = rgba.match(/[\d.]+/g);
                let alpha = values[3]
                if (alpha === undefined) {
                    alpha = 1
                }
                else if (alpha === '0') {
                    alpha = 0.01
                }
                const coords = fullStyle.match(/-?\d+px/g);
                console.log(alpha)

                if (coords && coords.length >= 3) {
                    const x = coords[0];
                    const y = coords[1];
                    const blur = coords[2];

                    Object.assign(data, { [key]: { color, x, y, blur, rgba, alpha, family, size } });
                } else {
                    console.log("Kein gültiger Schatten gefunden.");
                }
            }
            await fetchData(data, button, btnText)
        }

    </script>

    <script>
        async function fetchData(data, saveBtn, btnText) {
            try {
                const response = await fetch('/clipsplayer/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-Action-Type': 'Save-Follower-Settings'
                    },
                    body: JSON.stringify(data)
                })

                if (response.ok) {
                    saveBtn.innerText = "Erfolgreich gespeichert.";
                    saveBtn.style.animation = "rainbow 5s"
                    setTimeout(() => {
                        saveBtn.disabled = false;
                        saveBtn.style.color = "white"
                        saveBtn.innerText = btnText;
                        saveBtn.style.animation = null;
                    }, 5000);
                }
                else {
                    alert("Fehler beim Speichern");
                    saveBtn.disabled = false;
                    saveBtn.innerText = btnText;
                }

            } catch (error) {
                console.error(error);
                alert("Server nicht erreichbar.");
                saveBtn.disabled = false;
                saveBtn.innerText = btnText;
                saveBtn.animation = null;
            }
        }
    </script>
    <script>
        const clipFamily = document.getElementById('clipFamily')
        const clipSize = document.getElementById('clipSize')
        function updateFontClip() {
            testClip.style.fontFamily = clipFamily.value
            testClip.style.fontSize = clipSize.value + 'px'
        }
        clipFamily.addEventListener('change', updateFontClip)
        clipSize.addEventListener('input', updateFontClip)
    </script>
    <script>
        const headFamily = document.getElementById('headFamily')
        const headSize = document.getElementById('headSize')
        function updateFontHead() {
            testHead.style.fontFamily = headFamily.value
            testHead.style.fontSize = headSize.value + 'px'
        }
        headFamily.addEventListener('change', updateFontHead)
        headSize.addEventListener('input', updateFontHead)
    </script>
    <script>
        const clipPlayer = document.getElementById('clipsPlayer')
        async function loadClipPlayer(button) {
            clipPlayer.style.height = '900px'
            clipPlayer.innerHTML = `<iframe src="<%= link %>" frameborder="0" allow="autoplay; encrypted-media"></iframe>`
        }
    </script>