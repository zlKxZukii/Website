    async function getClip() {
        try {
            await fetch(`/clipsplayer/getclip`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key: key })
            });
        } catch (error) {
            console.error("Fehler beim Clip-Abruf:", error);
            // Bei Netzwerkfehler nach 3 Sek neu versuchen
            setTimeout(getClip, 3000);
        }
    }
</script>