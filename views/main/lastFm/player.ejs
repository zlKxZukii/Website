<script src="/socket.io/socket.io.js"></script>
<style>
    .bar {
        flex: 1;
        height: 15%;
        /* Farbenfroher Gradient: Lila -> Blau -> Türkis */
        background: linear-gradient(to top, var(--bottom, #00d2ff), var(--middle, '#4a00e0'), var(--top, '#8e2de2'));
        border-radius: 3px 3px 1px 1px;
        box-shadow: 0 0 8px rgba(0, 210, 255, 0.4);
        /* Glow-Effekt */
        transition: height 0.3s ease;
    }
</style>
<div id="player">
    <img id="artistImg" src="/img/logo.webp" alt="">
    <div id="info">
        <p style="font-size: 38px; height: 76px;" id="track">Scaletta in the Sun</p>
        <p style="font-size: 33px;" id="artist">Scaletta</p>
        <p style="font-size: 28px;" id="album">Wird Synchronisiert</p>
        <div id="viz-wrapper">
            <div id="bars"></div>
        </div>
    </div>
</div>
<script>
    const socket = io()
    const key = "<%= targetUser %>";
    const username = "<%= username %>";
    const settings = {
        barTop: "<%= barTop || '#8e2de2' %>",
        rotation: "<%= rotation || false %>",
        barBottom: "<%= barBottom || '#00d2ff' %>",
        barMiddle: "<%= barMiddle || '#4a00e0' %>",
        fontColor: "<%= fontColor || '#00d2ff' %>",
    }

    socket.on("connect", async () => {
        console.log("Verbunden für Raum: " + key);
        socket.emit("join-room", key);
        GetSong()
    });

    let reload;
    let intervallTime = 5000;
    const barContainer = document.getElementById('bars');
    const totalBars = 30;

    async function GetSong() {
        clearInterval(reload)
        const response = await fetch(`/lastfm/music/${key}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                username
            })
        })
        const statusMessage = await response.json()
        if (statusMessage.message === "retry") {
            setTimeout(() => {
                GetSong()
            }, 5000);
        }
    }

    socket.on("song", async (data) => {
        // { track, artist, album, nowPlaying, settings }
        if (data.nowPlaying === 'true') {
            const fontArr = ['track', 'artist', 'album']
            const image = document.getElementById('artistImg');
            if (data.img === "") {
                image.src = '/img/logo.webp'
            }
            else {
                image.src = data.img;
            }
            if (settings.rotation === true || settings.rotation === 'true') {
                image.style.animation = 'rotation-loop 12s linear infinite';
            }
            else {
                image.style.animation = null;
            }

            for (const font of fontArr) {
                const div = document.getElementById(font);
                div.innerText = data[font]
                div.style.color = settings.fontColor || '#55CBDB';
                // div.style.fontFamily = data.settings[font + "Family"] || null;
            }

            intervallTime = 5000
            barContainer.classList.add('playing');
            startIntervall()
        }
        else {
            barContainer.classList.remove('playing');
            GetSong()
        }
    })

    function startIntervall() {
        clearInterval(reload)
        reload = setInterval(() => {
            GetSong()
        }, intervallTime);
    }

    for (let i = 0; i < totalBars; i++) {
        const bar = document.createElement('div');
        bar.classList.add('bar');

        // Wir erstellen eine Sinus-ähnliche Verteilung für die Höhen
        // Damit die Mitte tendenziell höher springt als die Ränder
        const multiplier = Math.sin((i / totalBars) * Math.PI);
        const randomHeight = Math.floor(multiplier * 60 + Math.random() * 30 + 20) + "%";
        const randomDuration = (Math.random() * 0.3 + 0.4) + "s";

        bar.style.setProperty('--height', randomHeight);
        bar.style.setProperty('--duration', randomDuration);
        bar.style.setProperty('--top', settings.barTop)
        bar.style.setProperty('--middle', settings.barMiddle)
        bar.style.setProperty('--bottom', settings.barBottom)
        bar.style.animationDelay = (i * 0.05) + "s"; // Erzeugt einen Wellen-Effekt

        barContainer.appendChild(bar);
    }

</script>